__pycache__/
*.pyc
*.pyo
.pytest_cache/
start.cmd
start.sh

# Node — only needed to rebuild static/tailwind.css
node_modules/

# Schedule data — mostly runtime artifacts, except committed term exports
*.csv
*.xlsx
# Exceptions: these ship with the app so Render always has data after a deploy.
# Render's free-tier disk is ephemeral — an uploaded schedule vanishes on the
# next deploy, so commit each semester's Course_Schedule_<term>.csv here.
!schedule_default.csv
!Course_Schedule_*.csv

# Logs — may contain local paths / stack traces
*.log

# Uploaded schedules (written at runtime by /api/upload-schedule, one per term)
uploaded_schedule*
